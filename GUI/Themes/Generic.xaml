<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:local="clr-namespace:RDownloaderGUI">

    <!-- ==================== KeyValueItem DataTemplate (with delete button) ==================== -->
    <DataTemplate x:Key="KeyValueItemTemplate" DataType="{x:Type local:KeyValueItem}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     ui:ControlHelper.PlaceholderText="键"
                     Width="120"
                     Margin="0,0,4,0"/>
            <TextBox Grid.Column="1"
                     Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     ui:ControlHelper.PlaceholderText="值"
                     Margin="4,0,0,0"/>
            <Button Grid.Column="2"
                    Command="{Binding DeleteItemCommand, RelativeSource={RelativeSource AncestorType={x:Type local:DownloadSettings}}}" CommandParameter="{Binding}"
                    Margin="8,0,0,0"
                    Width="48"
                    VerticalAlignment="Center"
                    ToolTip="删除此项">
                <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Delete}"/>
            </Button>
        </Grid>
    </DataTemplate>

    <!-- ListViewItem style: two-way binds IsSelected to KeyValueItem.IsSelected -->
    <Style x:Key="SelectableListViewItem" TargetType="{x:Type ListViewItem}">
        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
        <Setter Property="Padding" Value="0,2"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>

    <!-- DNS ListViewItem style: native selection only (string has no IsSelected) -->
    <Style x:Key="DnsListViewItemStyle" TargetType="{x:Type ListViewItem}">
        <Setter Property="Padding" Value="0,2"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>

    <!-- 代理规则只读展示模板 -->
    <DataTemplate x:Key="ProxyRuleTemplate" DataType="{x:Type local:KeyValueItem}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding Key}"
                           VerticalAlignment="Center"/>
                <TextBlock Text=" → "
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource {x:Static ui:ThemeKeys.TextFillColorTertiaryBrushKey}}"/>
                <TextBlock Text="{Binding Value}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </DataTemplate>

    <!-- DNS 地址只读展示模板（绑定 ListViewItem.IsSelected） -->
    <DataTemplate x:Key="DnsAddressTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Text="{Binding}" VerticalAlignment="Center"/>
        </Grid>
    </DataTemplate>

    <!-- ==================== NewListItem ==================== -->
    <Style TargetType="{x:Type local:NewListItem}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:NewListItem}">
                    <Expander
                        Style="{DynamicResource {x:Static ui:ThemeKeys.ExpanderCardStyleKey}}"
                        ExpandDirection="Down"
                        Header="{TemplateBinding FileName}" HorizontalAlignment="Stretch">
                        <Expander.Content>
                            <StackPanel Orientation="Vertical">
                                <TextBox ui:ControlHelper.Header="链接"
                                         Text="{Binding Link, RelativeSource={RelativeSource TemplatedParent}, UpdateSourceTrigger=PropertyChanged}"/>
                                <CheckBox Content="使用全局下载设置"
                                          IsChecked="{Binding UseGlobalSettings, RelativeSource={RelativeSource TemplatedParent}}"
                                          Margin="0,8,0,0"/>
                                <local:DownloadSettings x:Name="PART_ItemDownloadSettings"
                                                        DownloadPath="{Binding DownloadPath, RelativeSource={RelativeSource TemplatedParent}}"
                                                        HeadersText="{Binding HeadersText, RelativeSource={RelativeSource TemplatedParent}}"
                                                        Margin="0,8,0,0">
                                    <local:DownloadSettings.Style>
                                        <Style TargetType="local:DownloadSettings">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UseGlobalSettings, RelativeSource={RelativeSource AncestorType={x:Type local:NewListItem}}}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </local:DownloadSettings.Style>
                                </local:DownloadSettings>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,8,0,0">
                                    <Button Content="删除"
                                            Command="{Binding DeleteCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            Padding="12,4"/>
                                </StackPanel>
                            </StackPanel>
                        </Expander.Content>
                    </Expander>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== DownloadSettings ==================== -->
    <Style TargetType="{x:Type local:DownloadSettings}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:DownloadSettings}">
                    <Expander x:Name="PART_RootExpander"
                        ExpandDirection="Down"
                        Header="下载设置">
                        <Expander.Content>
                            <StackPanel Orientation="Vertical" Margin="0,8,0,0">

                                <!-- 下载路径 -->
                                <TextBlock Text="保存到："
                                           FontSize="12"
                                           Foreground="{DynamicResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}"
                                           Margin="0,0,0,2"/>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PART_DownloadPathBox"
                                             Grid.Column="0"
                                             Text="{Binding DownloadPath, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ui:ControlHelper.PlaceholderText="留空使用默认路径"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0"/>
                                    <Button x:Name="PART_BrowsePathButton"
                                            Grid.Column="1"
                                            Content="浏览..."
                                            Padding="12,6"/>
                                </Grid>
                                <TextBlock x:Name="PART_DownloadPathDescription"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           Foreground="{DynamicResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}"/>
                                <TextBlock x:Name="PART_DownloadPathWarning"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           Foreground="{DynamicResource {x:Static ui:ThemeKeys.SystemFillColorCriticalBrushKey}}"
                                           Visibility="Collapsed"/>

                                <!-- 请求头设置 -->
                                <Expander x:Name="PART_HeadersExpander"
                                          ExpandDirection="Down"
                                          Header="请求头设置" Margin="0,8,0,0">
                                    <Expander.Content>
                                        <ui:NavigationView x:Name="PART_HeadersNavView"
                                                           IsBackButtonVisible="Collapsed"
                                                           IsSettingsVisible="False"
                                                           PaneDisplayMode="Top">
                                            <FrameworkElement.Resources>
                                                <SolidColorBrush x:Key="{x:Static ui:ThemeKeys.NavigationViewContentBackgroundKey}" Color="Transparent"/>
                                                <SolidColorBrush x:Key="{x:Static ui:ThemeKeys.ExpanderHeaderBorderBrushKey}" Color="Transparent"/>
                                                <Thickness x:Key="NavigationViewContentGridBorderThickness">0,0,0,0</Thickness>
                                            </FrameworkElement.Resources>

                                            <ui:NavigationView.MenuItems>
                                                <ui:NavigationViewItem Content="文本" Tag="Text" ui:ControlHelper.PlaceholderText="自定义请求头"/>
                                                <ui:NavigationViewItem Content="列表" Tag="List"/>
                                            </ui:NavigationView.MenuItems>

                                            <Grid Margin="0,8,0,8">
                                                <!-- 文本模式 -->
                                                <Grid>
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHeadersTextMode, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                    <TextBox AcceptsReturn="True"
                                                             Text="{Binding HeadersText, RelativeSource={RelativeSource TemplatedParent}}"/>
                                                </Grid>
                                                <!-- 列表模式 -->
                                                <Grid>
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHeadersTextMode, RelativeSource={RelativeSource TemplatedParent}}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                    <Grid>
                                                        <ListView x:Name="HeadersListView"
                                                                  ItemsSource="{Binding HeaderItems, RelativeSource={RelativeSource TemplatedParent}}"
                                                                  ItemTemplate="{StaticResource KeyValueItemTemplate}"
                                                                  SelectionMode="Single"
                                                                  HorizontalContentAlignment="Stretch">
                                                            <ListView.ItemContainerStyle>
                                                                <Style TargetType="ListViewItem">
                                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                                    <Setter Property="Focusable" Value="False"/>
                                                                    <Setter Property="Margin" Value="0,0,0,6"/>
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="ListViewItem">
                                                                                <ContentPresenter/>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </ListView.ItemContainerStyle>
                                                        </ListView>
                                                        <!-- 空状态：仅显示提示 -->
                                                        <Border x:Name="HeadersEmpty">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ElementName=HeadersListView, Path=HasItems}" Value="False">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <ui:IconAndText
                                                                Icon="{x:Static ui:SegoeFluentIcons.MapLayers}"
                                                                Orientation="Vertical"
                                                                IconSize="48"
                                                                FontSize="16">
                                                                <ui:IconAndText.Content>
                                                                    <StackPanel>
                                                                        <TextBlock Text="无自定义请求头" TextAlignment="Center"/>
                                                                        <ui:HyperlinkButton
                                                                            Content="点击添加"
                                                                            RaiseHyperlinkClicks="False"
                                                                            Command="{Binding AddHeaderItemCommand, RelativeSource={RelativeSource AncestorType={x:Type local:DownloadSettings}}}"
                                                                            HorizontalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </ui:IconAndText.Content>
                                                            </ui:IconAndText>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </ui:NavigationView>
                                    </Expander.Content>
                                </Expander>

                                <!-- 代理设置 -->
                                <Expander x:Name="PART_ProxyExpander"
                                          ExpandDirection="Down"
                                          Header="代理设置" Margin="0,8,0,0">
                                    <Expander.Content>
                                        <Grid>
                                            <ListView x:Name="ProxyListView"
                                                      ItemsSource="{TemplateBinding ProxyItems}"
                                                      ItemTemplate="{StaticResource ProxyRuleTemplate}"
                                                      SelectionMode="Multiple"
                                                      HorizontalContentAlignment="Stretch">
                                            </ListView>
                                            <!-- 空状态 -->
                                            <Border x:Name="ProxyEmpty">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ElementName=ProxyListView, Path=HasItems}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <ui:IconAndText
                                                    Icon="{x:Static ui:SegoeFluentIcons.MapLayers}"
                                                    Orientation="Vertical"
                                                    IconSize="48"
                                                    FontSize="16">
                                                    <ui:IconAndText.Content>
                                                        <StackPanel>
                                                            <TextBlock Text="暂无代理" TextAlignment="Center"/>
                                                            <ui:HyperlinkButton
                                                                Content="前往设置添加"
                                                                RaiseHyperlinkClicks="False"
                                                                Command="{Binding GoToSettingsCommand, RelativeSource={RelativeSource AncestorType={x:Type local:DownloadSettings}}}"
                                                                HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ui:IconAndText.Content>
                                                </ui:IconAndText>
                                            </Border>
                                        </Grid>
                                    </Expander.Content>
                                </Expander>

                                <!-- DNS 服务器 -->
                                <Expander x:Name="PART_DnsExpander"
                                          ExpandDirection="Down"
                                          Header="DNS 服务器" Margin="0,8,0,0">
                                    <Expander.Content>
                                        <Grid>
                                            <ListView x:Name="DnsListView"
                                                      ItemsSource="{TemplateBinding DnsItems}"
                                                      ItemTemplate="{StaticResource DnsAddressTemplate}"
                                                      SelectionMode="Multiple"
                                                      HorizontalContentAlignment="Stretch">
                                            </ListView>
                                            <!-- 空状态 -->
                                            <Border x:Name="DnsEmpty">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ElementName=DnsListView, Path=HasItems}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <ui:IconAndText
                                                    Icon="{x:Static ui:SegoeFluentIcons.MapLayers}"
                                                    Orientation="Vertical"
                                                    IconSize="48"
                                                    FontSize="16">
                                                    <ui:IconAndText.Content>
                                                        <StackPanel>
                                                            <TextBlock Text="暂无 DNS 服务器" TextAlignment="Center"/>
                                                            <ui:HyperlinkButton
                                                                Content="前往设置添加"
                                                                RaiseHyperlinkClicks="False"
                                                                Command="{Binding GoToSettingsCommand, RelativeSource={RelativeSource AncestorType={x:Type local:DownloadSettings}}}"
                                                                HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ui:IconAndText.Content>
                                                </ui:IconAndText>
                                            </Border>
                                        </Grid>
                                    </Expander.Content>
                                </Expander>

                            </StackPanel>
                        </Expander.Content>
                    </Expander>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsGlobal, RelativeSource={RelativeSource Self}}" Value="True">
                            <Setter TargetName="PART_RootExpander" Property="Header" Value="全局下载设置"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
