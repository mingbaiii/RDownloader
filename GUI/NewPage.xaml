<Page x:Class="RDownloaderGUI.NewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:RDownloaderGUI"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="500"
      Title="NewPage">

    <Grid>
        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBox x:Name="UrlTextBox"
                     Width="400" MinHeight="96"
                     ui:ControlHelper.PlaceholderText="下载链接（每行一个）"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
            />
            <Button x:Name="ParseButton"
                    Margin="0,16,0,0" Height="32" Width="96"
                    Content="高级选项"
                    Style="{DynamicResource {x:Static ui:ThemeKeys.AccentButtonStyleKey}}"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Click="Button_Click"/>
            <Button x:Name="DirectDownloadButton"
                    Margin="0,8,0,0" Height="32" Width="96"
                    Content="直接下载"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Click="DirectDownload_Click"/>

            <!-- 探测进度 -->
            <StackPanel x:Name="ProgressPanel"
                        Orientation="Vertical"
                        HorizontalAlignment="Center"
                        Visibility="Collapsed"
                        Margin="0,16,0,0">
                <ui:ProgressRing Width="48" Height="48"
                                 IsIndeterminate="True"
                                 Background="Transparent"
                                 HorizontalAlignment="Center"/>
                <TextBlock x:Name="ProgressText"
                           Text="正在解析链接..."
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
