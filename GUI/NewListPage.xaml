<Page x:Class="RDownloaderGUI.NewListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:RDownloaderGUI"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="500"
      Title="NewListPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 可滚动内容区 -->
        <ui:ScrollViewerEx Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ItemStackPanel" Orientation="Vertical" Margin="8,8,8,8">

                <!-- 动态探测结果列表 -->
                <ItemsControl x:Name="ProbeItemsControl"
                              HorizontalContentAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- 全局下载设置 -->
                <local:DownloadSettings x:Name="GlobalSettings" Margin="8,8,8,8" IsGlobal="True">
                </local:DownloadSettings>

            </StackPanel>
        </ui:ScrollViewerEx>

        <!-- 底部按钮 + 进度 -->
        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="8,0,8,8">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,0">
                <TextBlock x:Name="ReprobeProgressText"
                           Visibility="Collapsed"
                           VerticalAlignment="Center"/>
                <ui:HyperlinkButton x:Name="ReparseHyperlinkButton"
                                    Content="重新解析"
                                    Click="ReparseHyperlinkButton_Click"
                                    Visibility="Collapsed"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,8,0,0">
                <Button x:Name="BackButton"
                        Content="返回"
                        Width="80" Height="32"
                        Margin="0,0,8,0"
                        Click="BackButton_Click"/>
                <Button x:Name="EndpointButton"
                        Content="配置节点"
                        Width="96" Height="32"
                        Margin="0,0,8,0"
                        Click="EndpointButton_Click"/>
                <Button x:Name="StartDownloadButton"
                        Content="开始下载"
                        Width="96" Height="32"
                        Style="{DynamicResource {x:Static ui:ThemeKeys.AccentButtonStyleKey}}"
                        Click="StartDownloadButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
