<Page x:Class="RDownloaderGUI.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:RDownloaderGUI"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      mc:Ignorable="d"
      d:DesignHeight="1000" d:DesignWidth="600"
      Title="设置">

    <Page.Resources>
        <sys:Double x:Key="SettingsCardSpacing">4</sys:Double>

        <Style x:Key="SettingsSectionHeaderTextBlockStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="1,30,0,6" />
            <Setter Property="Foreground"
                    Value="{DynamicResource {x:Static ui:ThemeKeys.TextFillColorPrimaryBrushKey}}" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#D32F2F" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#B71C1C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B71C1C" />
                                <Setter Property="BorderBrush" Value="#7F0000" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#7F0000" />
                                <Setter Property="BorderBrush" Value="#4A0000" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsDescriptionStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground"
                    Value="{DynamicResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <!-- ==================== 列表行模板 ==================== -->

        <!-- DNS 服务器列表行 -->
        <DataTemplate x:Key="DnsItemTemplate" DataType="{x:Type local:DnsItem}">
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ui:ControlHelper.PlaceholderText="DNS 服务器地址"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Width="30" Height="30"
                            Click="MoveDnsUp_Click"
                            Padding="0"
                            ToolTip="上移"
                            Margin="0,0,2,0">
                        <ui:FontIcon Glyph="&#xE70E;" FontSize="12"/>
                    </Button>
                    <Button Width="30" Height="30"
                            Click="MoveDnsDown_Click"
                            Padding="0"
                            ToolTip="下移"
                            Margin="0,0,2,0">
                        <ui:FontIcon Glyph="&#xE70D;" FontSize="12"/>
                    </Button>
                    <Button Width="30" Height="30"
                            Click="DeleteDns_Click"
                            Padding="0"
                            ToolTip="删除此 DNS 服务器">
                        <ui:FontIcon Glyph="&#xE74D;" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- 请求头 列表行（无启用/禁用） -->
        <DataTemplate x:Key="KeyValueRowTemplate" DataType="{x:Type local:KeyValueItem}">
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ui:ControlHelper.PlaceholderText="键"
                         VerticalAlignment="Center"
                         Margin="0,0,4,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ui:ControlHelper.PlaceholderText="值"
                         VerticalAlignment="Center"
                         Margin="4,0,8,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Width="30" Height="30"
                            Click="MoveItemUp_Click"
                            Padding="0"
                            ToolTip="上移"
                            Margin="0,0,2,0">
                        <ui:FontIcon Glyph="&#xE70E;" FontSize="12"/>
                    </Button>
                    <Button Width="30" Height="30"
                            Click="MoveItemDown_Click"
                            Padding="0"
                            ToolTip="下移"
                            Margin="0,0,2,0">
                        <ui:FontIcon Glyph="&#xE70D;" FontSize="12"/>
                    </Button>
                    <Button Width="30" Height="30"
                            Click="DeleteItem_Click"
                            Padding="0"
                            ToolTip="删除此项">
                        <ui:FontIcon Glyph="&#xE74D;" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- 代理规则 列表行（启用/禁用通过 ListView 选择） -->
        <DataTemplate x:Key="ProxyRowTemplate" DataType="{x:Type local:KeyValueItem}">
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ui:ControlHelper.PlaceholderText="键"
                         VerticalAlignment="Center"
                         Margin="0,0,4,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ui:ControlHelper.PlaceholderText="值"
                         VerticalAlignment="Center"
                         Margin="4,0,8,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Width="30" Height="30"
                            Click="MoveItemUp_Click"
                            Padding="0"
                            ToolTip="上移"
                            Margin="0,0,2,0">
                        <ui:FontIcon Glyph="&#xE70E;" FontSize="12"/>
                    </Button>
                    <Button Width="30" Height="30"
                            Click="MoveItemDown_Click"
                            Padding="0"
                            ToolTip="下移"
                            Margin="0,0,2,0">
                        <ui:FontIcon Glyph="&#xE70D;" FontSize="12"/>
                    </Button>
                    <Button Width="30" Height="30"
                            Click="DeleteItem_Click"
                            Padding="0"
                            ToolTip="删除此项">
                        <ui:FontIcon Glyph="&#xE74D;" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Grid>
        </DataTemplate>

    </Page.Resources>

    <ScrollViewer Padding="20,0">
        <Grid>
            <StackPanel MaxWidth="1000"
                        HorizontalAlignment="Stretch">

                <!-- ==================== 网络 ==================== -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="网络" />

                <ui:SettingsCard Header="IP 协议"
                                 Description="选择使用的 IP 协议版本。"
                                 Margin="0,4,0,0">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE839;" />
                    </ui:SettingsCard.HeaderIcon>
                    <ComboBox x:Name="IpProtocolCombo"
                              Width="140"
                              >
                        <ComboBoxItem Content="IPv4 + IPv6" Tag="Both" />
                        <ComboBoxItem Content="仅 IPv4" Tag="OnlyIPv4" />
                        <ComboBoxItem Content="仅 IPv6" Tag="OnlyIPv6" />
                    </ComboBox>
                </ui:SettingsCard>

                <ui:SettingsCard Header="连接数"
                                 Description="同时使用的下载连接总数。"
                                 Margin="0,4,0,0">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Glyph="&#xEA3C;" />
                    </ui:SettingsCard.HeaderIcon>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <ui:NumberBox x:Name="ConnectionsBox"
                                 Width="100"
                                 MinWidth="0"
                                 SmallChange="1"
                                 LargeChange="1"
                                 SpinButtonPlacementMode="Compact"
                                 TextAlignment="Right" />
                        <TextBlock Text=" 个"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}" />
                    </StackPanel>
                </ui:SettingsCard>

                <Expander Style="{DynamicResource {x:Static ui:ThemeKeys.ExpanderCardStyleKey}}"
                         ExpandDirection="Down"
                         Margin="0,4,0,0"
                         HorizontalAlignment="Stretch">
                    <Expander.Header>
                        <StackPanel Margin="4,16">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE774;" FontSize="16"
                                             Margin="0,0,8,0"/>
                                <TextBlock Text="DNS 服务器" FontSize="15"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="自定义 DNS 服务器地址，支持 DoH。留空则使用系统 DNS。"
                                       Style="{StaticResource SettingsDescriptionStyle}"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="4,0,4,4">
                        <ListView x:Name="DnsListView"
                                  ItemTemplate="{StaticResource DnsItemTemplate}"
                                  HorizontalContentAlignment="Stretch"
                                  VerticalContentAlignment="Center"
                                  SelectionMode="Multiple"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  HorizontalAlignment="Stretch"/>
                        <Button Click="AddDns_Click"
                                Margin="0,6,0,0"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE710;" Margin="0,0,6,0"/>
                                <TextBlock Text="添加 DNS 服务器"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Expander>

                <ui:SettingsCard Header="DNS 查询超时"
                                 Description="单次 DNS 查询的超时时间。"
                                 Margin="0,4,0,0">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE823;" />
                    </ui:SettingsCard.HeaderIcon>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <ui:NumberBox x:Name="DnsTimeoutBox"
                         Width="100"
                         MinWidth="0"
                         SmallChange="1"
                         LargeChange="1"
                         SpinButtonPlacementMode="Compact"
                         TextAlignment="Right" />
                        <TextBlock Text=" 秒"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}" />
                    </StackPanel>
                </ui:SettingsCard>

                <!-- ==================== 下载路径 ==================== -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="下载路径" />

                <ui:SettingsCard Header="下载目录"
                                 Margin="0,4,0,0">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE838;" />
                    </ui:SettingsCard.HeaderIcon>
                    <ui:SettingsCard.Description>
                        <StackPanel>
                            <TextBlock x:Name="DownloadPathDescription" TextWrapping="Wrap"/>
                            <TextBlock x:Name="DownloadPathWarning"
                                       Foreground="{DynamicResource {x:Static ui:ThemeKeys.SystemFillColorCriticalBrushKey}}"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </ui:SettingsCard.Description>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DownloadPathBox"
                                 Grid.Column="0"
                                 ui:ControlHelper.PlaceholderText="留空使用默认路径"
                                 VerticalAlignment="Center"
                                 Margin="0,0,8,0"
                                 MaxWidth="200"
                                 MinWidth="200"/>
                        <Button Grid.Column="1"
                                x:Name="BrowseDownloadPathButton"
                                Content="浏览..."
                                Padding="12,6"
                                Click="BrowseDownloadPath_Click"/>
                    </Grid>
                </ui:SettingsCard>

                <!-- ==================== RPC 服务器 ==================== -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="Aria2 RPC 服务器" />

                <ui:SettingsCard Header="端口"
                                 Description="Aria2 JSON-RPC 服务器监听端口，修改后即时生效。默认 6800。"
                                 Margin="0,4,0,0">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE839;" />
                    </ui:SettingsCard.HeaderIcon>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <ui:NumberBox x:Name="RpcPortBox"
                                 Width="100"
                                 MinWidth="0"
                                 SmallChange="1"
                                 LargeChange="1"
                                 SpinButtonPlacementMode="Compact"
                                 TextAlignment="Right" />
                        <TextBlock Text=" 端口"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}" />
                    </StackPanel>
                </ui:SettingsCard>

                <ui:SettingsCard Header="RPC Secret"
                                 Description="Aria2 RPC 认证密钥。留空则无认证。修改后即时生效。"
                                 Margin="0,4,0,0">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE72E;" />
                    </ui:SettingsCard.HeaderIcon>
                    <TextBox x:Name="RpcSecretBox"
                             Width="200"
                             ui:ControlHelper.PlaceholderText="留空 = 无认证"
                             VerticalAlignment="Center" />
                </ui:SettingsCard>

                <!-- ==================== 调试 ==================== -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="调试" />

                <ui:SettingsCard Header="调试日志窗口"
                                 Description="实时显示信日志"
                                 Margin="0,4,0,0">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE9F9;" />
                    </ui:SettingsCard.HeaderIcon>
                    <ui:ToggleSwitch x:Name="DebugModeToggle"
                              OnContent = "开启"
                              OffContent = "关闭"
                              VerticalAlignment="Center" />
                </ui:SettingsCard>

                <!-- ==================== 下载调优 ==================== -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="下载调优" />

                <ui:SettingsCard Header="分块大小"
                                 Description="每个下载连接的分块大小，影响内存占用和下载效率。"
                                 Margin="0,4,0,0">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE950;" />
                    </ui:SettingsCard.HeaderIcon>
                    <ComboBox x:Name="ChunkSizeCombo"
                              Width="220" />
                </ui:SettingsCard>

                <ui:SettingsCard Header="速度阈值"
                                 Description="自动分配连接的速度阈值倍率。低于此速度的连接会减少分块分配。"
                                 Margin="0,4,0,0">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE8A9;" />
                    </ui:SettingsCard.HeaderIcon>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <ui:NumberBox x:Name="SpeedThresholdBox"
                             Width="100"
                             MinWidth="0"
                             SmallChange="0.1"
                             LargeChange="0.1"
                             SpinButtonPlacementMode="Compact"
                             TextAlignment="Right" />
                        <TextBlock Text=" 倍"
                                   VerticalAlignment="Center"
                                   Margin="4,0,0,0"
                                   Foreground="{DynamicResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}" />
                    </StackPanel>
                </ui:SettingsCard>

                <ui:SettingsCard Header="下载超时"
                                 Description="下载连接超时时间，超时后会尝试重连。"
                                 Margin="0,4,0,0">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE823;" />
                    </ui:SettingsCard.HeaderIcon>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <ui:NumberBox x:Name="DownloadTimeoutBox"
                         Width="100"
                         MinWidth="0"
                         SmallChange="1"
                         LargeChange="1"
                         SpinButtonPlacementMode="Compact"
                         TextAlignment="Right" />
                        <TextBlock Text=" 秒"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}" />
                    </StackPanel>
                </ui:SettingsCard>

                <ui:SettingsCard Header="连通性测试超时"
                                 Description="单个端点的 TCP 连通性测试超时时间。"
                                 Margin="0,4,0,0">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE823;" />
                    </ui:SettingsCard.HeaderIcon>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <ui:NumberBox x:Name="ConnectivityTimeoutBox"
                         Width="100"
                         MinWidth="0"
                         SmallChange="1"
                         LargeChange="1"
                         SpinButtonPlacementMode="Compact"
                         TextAlignment="Right" />
                        <TextBlock Text=" 秒"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}" />
                    </StackPanel>
                </ui:SettingsCard>

                <!-- ==================== 重试设置 ==================== -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="重试设置" />

                <ui:SettingsExpander Header="重试参数"
                                     Description="下载过程中的各类重试次数与容错设置。"
                                     Margin="0,4,0,0">
                    <ui:SettingsExpander.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE895;" />
                    </ui:SettingsExpander.HeaderIcon>
                    <ui:SettingsExpander.Items>
                        <ui:SettingsCard Header="下载重试次数"
                                         Description="下载失败后的重试次数。"
                                         Margin="0,0,0,4">
                            <ui:NumberBox x:Name="RetryCountBox"
                                          Width="100"
                                          MinWidth="0"
                                          SmallChange="1"
                                          LargeChange="1"
                                          SpinButtonPlacementMode="Compact"
                                          TextAlignment="Right" />
                        </ui:SettingsCard>
                        <ui:SettingsCard Header="重连次数"
                                         Description="连接断开后的重连次数。"
                                         Margin="0,0,0,4">
                            <ui:NumberBox x:Name="RetryReconnectBox"
                                          Width="100"
                                          MinWidth="0"
                                          SmallChange="1"
                                          LargeChange="1"
                                          SpinButtonPlacementMode="Compact"
                                          TextAlignment="Right" />
                        </ui:SettingsCard>
                        <ui:SettingsCard Header="重新获取端点次数"
                                         Description="当前端点全部失效后重新获取端点的次数。"
                                         Margin="0,0,0,4">
                            <ui:NumberBox x:Name="RetryRefetchEndpointBox"
                                          Width="100"
                                          MinWidth="0"
                                          SmallChange="1"
                                          LargeChange="1"
                                          SpinButtonPlacementMode="Compact"
                                          TextAlignment="Right" />
                        </ui:SettingsCard>
                        <ui:SettingsCard Header="重新获取 URL 次数"
                                         Description="URL 过期后重新获取下载地址的次数。"
                                         Margin="0,0,0,4">
                            <ui:NumberBox x:Name="RetryRefetchUrlBox"
                                          Width="100"
                                          MinWidth="0"
                                          SmallChange="1"
                                          LargeChange="1"
                                          SpinButtonPlacementMode="Compact"
                                          TextAlignment="Right" />
                        </ui:SettingsCard>
                        <ui:SettingsCard Header="Content-Length=0 重试次数"
                                         Description="响应 Content-Length 为 0 时的重试次数。"
                                         Margin="0,0,0,4">
                            <ui:NumberBox x:Name="ContentLengthZeroRetryBox"
                                          Width="100"
                                          MinWidth="0"
                                          SmallChange="1"
                                          LargeChange="1"
                                          SpinButtonPlacementMode="Compact"
                                          TextAlignment="Right" />
                        </ui:SettingsCard>
                        <ui:SettingsCard Header="端点失败阈值"
                                         Description="端点在连续失败达到此次数后将被自动禁用。">
                            <ui:NumberBox x:Name="EndpointFailureThresholdBox"
                                          Width="100"
                                          MinWidth="0"
                                          SmallChange="1"
                                          LargeChange="1"
                                          SpinButtonPlacementMode="Compact"
                                          TextAlignment="Right" />
                        </ui:SettingsCard>
                        <ui:SettingsCard Header="测速重试次数"
                                         Description="速度测试失败后的重试次数。"
                                         Margin="0,0,0,4">
                            <ui:NumberBox x:Name="SpeedTestRetryCountBox"
                                          Width="100"
                                          MinWidth="0"
                                          SmallChange="1"
                                          LargeChange="1"
                                          SpinButtonPlacementMode="Compact"
                                          TextAlignment="Right" />
                        </ui:SettingsCard>
                        <ui:SettingsCard Header="测速超时"
                                         Description="单个速度测试的超时时间。">
                            <ui:NumberBox x:Name="SpeedTestTimeoutBox"
                                          Width="100"
                                          MinWidth="0"
                                          SmallChange="1"
                                          LargeChange="1"
                                          SpinButtonPlacementMode="Compact"
                                          TextAlignment="Right" />
                        </ui:SettingsCard>
                        <ui:SettingsCard Header="DNS 重试次数"
                                         Description="DNS 查询失败后的重试次数。"
                                         Margin="0,0,0,4">
                            <ui:NumberBox x:Name="DnsRetryCountBox"
                                          Width="100"
                                          MinWidth="0"
                                          SmallChange="1"
                                          LargeChange="1"
                                          SpinButtonPlacementMode="Compact"
                                          TextAlignment="Right" />
                        </ui:SettingsCard>
                    </ui:SettingsExpander.Items>
                </ui:SettingsExpander>

                <!-- ==================== 调度器 ==================== -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="调度器" />

                <ui:SettingsExpander Header="调度参数"
                                     Description="控制连接调度与动态分配的阈值。"
                                     Margin="0,4,0,0">
                    <ui:SettingsExpander.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE8A9;" />
                    </ui:SettingsExpander.HeaderIcon>
                    <ui:SettingsExpander.Items>
                        <ui:SettingsCard Header="检查间隔"
                                         Description="调度器检查速度并重新分配分块的间隔。"
                                         Margin="0,0,0,4">
                            <ui:NumberBox x:Name="SchedulerCheckIntervalBox"
                                          Width="100"
                                          MinWidth="0"
                                          SmallChange="1"
                                          LargeChange="1"
                                          SpinButtonPlacementMode="Compact"
                                          TextAlignment="Right" />
                        </ui:SettingsCard>
                        <ui:SettingsCard Header="慢节点阈值"
                                         Description="低于平均速度此比例（0~1）的连接视为慢节点。"
                                         Margin="0,0,0,4">
                            <ui:NumberBox x:Name="SchedulerSlowThresholdBox"
                                          Width="100"
                                          MinWidth="0"
                                          SmallChange="0.1"
                                          LargeChange="0.1"
                                          SpinButtonPlacementMode="Compact"
                                          TextAlignment="Right" />
                        </ui:SettingsCard>
                        <ui:SettingsCard Header="重新分配阈值"
                                         Description="速度变化超过此比例（0~1）时触发分块重新分配。">
                            <ui:NumberBox x:Name="SchedulerReallocateThresholdBox"
                                          Width="100"
                                          MinWidth="0"
                                          SmallChange="0.1"
                                          LargeChange="0.1"
                                          SpinButtonPlacementMode="Compact"
                                          TextAlignment="Right" />
                        </ui:SettingsCard>
                    </ui:SettingsExpander.Items>
                </ui:SettingsExpander>

                <!-- ==================== 自定义请求头 ==================== -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="自定义请求头" />

                <Expander Style="{DynamicResource {x:Static ui:ThemeKeys.ExpanderCardStyleKey}}"
                         ExpandDirection="Down"
                         Margin="0,4,0,0"
                         HorizontalAlignment="Stretch">
                    <Expander.Header>
                        <StackPanel Margin="4,16">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE8D2;" FontSize="16"
                                             Margin="0,0,8,0"/>
                                <TextBlock Text="全局请求头" FontSize="15"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="对所有下载任务生效的自定义 HTTP 请求头。"
                                       Style="{StaticResource SettingsDescriptionStyle}"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="4,0,4,4">
                        <ListView x:Name="HeadersListView"
                                  ItemTemplate="{StaticResource KeyValueRowTemplate}"
                                  HorizontalContentAlignment="Stretch"
                                  VerticalContentAlignment="Center"
                                  SelectionMode="Single"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  HorizontalAlignment="Stretch"/>
                        <Button Click="AddHeader_Click"
                                Margin="0,6,0,0"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE710;" Margin="0,0,6,0"/>
                                <TextBlock Text="添加请求头"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Expander>

                <!-- ==================== 代理设置 ==================== -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="代理设置" />

                <Expander Style="{DynamicResource {x:Static ui:ThemeKeys.ExpanderCardStyleKey}}"
                         ExpandDirection="Down"
                         Margin="0,4,0,0"
                         HorizontalAlignment="Stretch">
                    <Expander.Header>
                        <StackPanel Margin="4,16">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE8A7;" FontSize="16"
                                             Margin="0,0,8,0"/>
                                <TextBlock Text="代理规则" FontSize="15"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="* 表示全局代理；dns:* 表示所有 DNS 查询代理；1.2.3.4 表示特定 IP 代理。&#x0a;代理 URL 格式：http://host:port 或 socks5://host:port"
                                       Style="{StaticResource SettingsDescriptionStyle}"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="4,0,4,4">
                        <ListView x:Name="ProxyListView"
                                  ItemTemplate="{StaticResource ProxyRowTemplate}"
                                  HorizontalContentAlignment="Stretch"
                                  VerticalContentAlignment="Center"
                                  SelectionMode="Multiple"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  HorizontalAlignment="Stretch"/>
                        <Button Click="AddProxy_Click"
                                Margin="0,6,0,0"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE710;" Margin="0,0,6,0"/>
                                <TextBlock Text="添加代理规则"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Expander>

                <!-- ==================== 维护 ==================== -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="维护" />

                <ui:SettingsCard Header="清理所有文件"
                                 Description="删除程序所有相关文件，完成后关闭程序。"
                                 Margin="0,4,0,0">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE74D;" />
                    </ui:SettingsCard.HeaderIcon>
                    <Button x:Name="CleanFilesButton"
                            Content="清理"
                            Style="{StaticResource DangerButtonStyle}">
                        <ui:FlyoutService.Flyout>
                            <ui:Flyout x:Name="CleanFilesFlyout" Placement="Top">
                                <StackPanel>
                                    <TextBlock Margin="0,0,0,12"
                                        Text="确定要删除所有文件吗？&#10;完成后将自动关闭程序。" />
                                    <Grid>
                                        <Button Click="CleanFilesConfirmation_Click" Content="确认清理"
                                        Style="{StaticResource DangerButtonStyle}" HorizontalAlignment="Right" />
                                    </Grid>
                                </StackPanel>
                            </ui:Flyout>
                        </ui:FlyoutService.Flyout>
                    </Button>
                </ui:SettingsCard>

                <!-- ==================== 底部按钮 ==================== -->
                <StackPanel HorizontalAlignment="Right"
                            Margin="0,30,0,30">
                    <Button x:Name="ResetButton"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="16,8">
                        <ui:FlyoutService.Flyout>
                            <ui:Flyout x:Name="ResetFlyout" Placement="Top">
                                <StackPanel>
                                    <TextBlock Margin="0,0,0,12"
                                        Text="确定要恢复为默认设置吗？" />
                                    <Grid>
                                        <Button Click="ResetConfirmation_Click" Content="确认"
                                        Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Right" />
                                    </Grid>
                                </StackPanel>
                            </ui:Flyout>
                        </ui:FlyoutService.Flyout>
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE777;" Margin="0,0,6,0"/>
                            <TextBlock Text="恢复默认"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
